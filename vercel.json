{
  "version": 2,
  "installCommand": "npm ci --prefix frontend && npm ci --prefix backend",
  "buildCommand": "npm run build --prefix frontend",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/[...path].js": {
      "includeFiles": [
        "backend/controllers/**",
        "backend/db/**",
        "backend/middleware/**",
        "backend/routes/**",
        "backend/server.js",
        "backend/package.json",
        "backend/package-lock.json"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
