{
  "version": 2,
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/[...path].js": {
      "includeFiles": [
        "controllers/**",
        "db/**",
        "middleware/**",
        "routes/**",
        "server.js",
        "package.json",
        "package-lock.json"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
